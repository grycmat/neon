# Copy to `secrets.properties` (gitignored) and fill in real values.
# Build-time secrets consumed by core/data/build.gradle.kts -> BuildConfig.

# Base URL of your deployed mastodon-fcm-relay (no trailing slash).
# If unset, the build falls back to https://relay.example.com (push won't work).
RELAY_BASE_URL=https://relay.example.com
